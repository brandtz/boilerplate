{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "dashboard-parse": "./bin/dashboard-parse.ts"
  },
  "scripts": {
    "predev": "tsx bin/dashboard-parse.ts --repo .. --output public/dashboard-state.json --pretty || echo Parse completed with warnings",
    "dev": "next dev",
    "prebuild": "tsx bin/dashboard-parse.ts --repo .. --output public/dashboard-state.json --pretty || echo Parse completed with warnings",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --testPathIgnorePatterns='tests/perf'",
    "test:watch": "jest --watch --testPathIgnorePatterns='tests/perf'",
    "test:coverage": "jest --coverage --testPathIgnorePatterns='tests/perf'",
    "test:perf": "jest --testPathPatterns='tests/perf' --no-coverage --verbose",
    "parse": "tsx bin/dashboard-parse.ts",
    "parse:json": "tsx bin/dashboard-parse.ts --output dashboard-state.json --pretty"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
